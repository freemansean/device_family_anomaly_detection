# ─────────────────────────────────────────────
# Sasquatch — .env template
# ─────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# `setup.sh` will copy it automatically if `.env` does not exist.
#
# Without MIST_API_TOKEN + MIST_ORG_ID set, the dashboard will load
# but "Collect Events" will fail — there is no demo / sample-data mode.

# ─────────────────────────────────────────────
# Mist API (REQUIRED for any real data)
# ─────────────────────────────────────────────
# Mist API token with read access to client events.
MIST_API_TOKEN=
# Regional API host. Examples: api.mist.com, api.gc1.mist.com, api.gc2.mist.com,
# api.gc4.mist.com, api.eu.mist.com. Do NOT include /api/v1 — that is path, not host.
MIST_CLOUD_HOST=api.mist.com
# Org UUID — required. Per-site collection has been retired.
MIST_ORG_ID=

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Webhook (webhook_dispatcher.py)
# ─────────────────────────────────────────────
# Webhook URL, scope, Marvis TSHOOT enrichment, and family-size threshold are
# managed via the GUI (Webhook Config panel) and persisted in Redis
# (sasquatch:webhook_config). ANOMALY_WEBHOOK_URL below is only used as the
# bootstrap default before an admin saves a value in the GUI — leave blank to
# start with dispatch disabled.
ANOMALY_WEBHOOK_URL=

# ─────────────────────────────────────────────
# CORS (main.py)
# ─────────────────────────────────────────────
# Comma-separated list of origins the browser is allowed to load the app from.
# Default (env unset) covers http://localhost:3000, http://127.0.0.1:3000, and
# the same on :5173 — enough for a local `./start.sh` run.
# If you serve the dashboard from a LAN IP (e.g. http://192.0.2.10:3000), add
# that exact origin here or every fetch fails with "Failed to fetch" in the
# browser console. Use "*" on an isolated/trusted network to allow all origins.
# Example: SASQUATCH_CORS_ORIGINS=http://10.0.1.250:3000,http://localhost:3000
SASQUATCH_CORS_ORIGINS=

# ─────────────────────────────────────────────
# ML / Scheduling / Health config
# ─────────────────────────────────────────────
# All ML tuning, scheduling, and health-score settings have sensible
# defaults in config.py and are managed via the GUI (General Config /
# Anomaly Config panels). Values are persisted in config_overrides.json.
# Environment variables are honoured as a middle-tier override if set,
# but are not required. See config.py DEFAULTS for the full list.
