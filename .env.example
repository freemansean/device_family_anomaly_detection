# ─────────────────────────────────────────────
# Sasquatch — .env template
# ─────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# `setup.sh` will copy it automatically if `.env` does not exist.
#
# Without MIST_API_TOKEN + MIST_ORG_ID set, the dashboard will load
# but "Collect Events" will fail — there is no demo / sample-data mode.

# ─────────────────────────────────────────────
# Mist API (REQUIRED for any real data)
# ─────────────────────────────────────────────
# Mist API token with read access to client events.
MIST_API_TOKEN=
# Regional API host. Examples: api.mist.com, api.gc1.mist.com, api.gc2.mist.com,
# api.gc4.mist.com, api.eu.mist.com. Do NOT include /api/v1 — that is path, not host.
MIST_CLOUD_HOST=api.mist.com
# Org UUID — required. Per-site collection has been retired.
MIST_ORG_ID=

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Webhook (webhook_dispatcher.py)
# ─────────────────────────────────────────────
# Dual gate: is_family_outlier AND health_score < threshold.
# Leave blank to disable dispatch (alert sessions are still recorded).
ANOMALY_WEBHOOK_URL=

# ─────────────────────────────────────────────
# Client TSHOOT Enrichment (webhook_dispatcher.py)
# ─────────────────────────────────────────────
# Set to "false" to skip Marvis TSHOOT enrichment on outbound webhooks.
MIST_TSHOOT_ENABLED=true

# ─────────────────────────────────────────────
# App Auth (api/auth.py)
# ─────────────────────────────────────────────
# Basic credentials for the dashboard login. Change these before exposing
# the app beyond your local machine.
APP_USERNAME=admin
APP_PASSWORD=changeme

# ─────────────────────────────────────────────
# ML / Scheduling / Health config
# ─────────────────────────────────────────────
# All ML tuning, scheduling, and health-score settings have sensible
# defaults in config.py and are managed via the GUI (General Config /
# Anomaly Config panels). Values are persisted in config_overrides.json.
# Environment variables are honoured as a middle-tier override if set,
# but are not required. See config.py DEFAULTS for the full list.
