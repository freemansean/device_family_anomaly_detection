# Fresh-clone default — points the built frontend at a backend on the same host.
# For LAN access (e.g. hitting the dashboard from another device on your network),
# create `sasquatch/frontend/.env.production.local` with an override such as:
#     VITE_API_BASE_URL=http://192.0.2.10:8000
# `.env.production.local` is gitignored, so the LAN override stays local to your
# machine and does not leak into other checkouts.
VITE_API_BASE_URL=http://localhost:8000
