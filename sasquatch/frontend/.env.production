# Default: empty string → frontend uses relative URLs (/api/...), which the
# serving host proxies to the backend. Works under Docker (nginx proxies /api/
# to the backend container) and under a same-origin dev setup.
#
# For a split deploy where the frontend is served from a different host than
# the backend, create `sasquatch/frontend/.env.production.local` with:
#     VITE_API_BASE_URL=http://192.0.2.10:8000
# `.env.production.local` is gitignored, so the override stays local.
VITE_API_BASE_URL=
